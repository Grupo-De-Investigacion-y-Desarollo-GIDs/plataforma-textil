<?xml version="1.0"?><?mso-application progid="Excel.Sheet"?><Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet"><Styles><Style ss:ID="header"><Font ss:Bold="1"/><Interior ss:Color="#1e3a5f" ss:Pattern="Solid"/><Font ss:Color="#FFFFFF" ss:Bold="1"/></Style></Styles><Worksheet ss:Name="Issues 20-04-2026"><Table><Column ss:Width="60"/><Column ss:Width="280"/><Column ss:Width="180"/><Column ss:Width="140"/><Column ss:Width="400"/><Row><Cell ss:StyleID="header"><Data ss:Type="String">Issue</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">Titulo</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">Spec</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">Tipo de resolución</Data></Cell><Cell ss:StyleID="header"><Data ss:Type="String">Solución</Data></Cell></Row><Row><Cell><Data ss:Type="String">#50</Data></Cell><Cell><Data ss:Type="String">Taller subió a 50 pts pero no se recategorizó como Plata</Data></Cell><Cell><Data ss:Type="String">v2-log-niveles-bidireccional</Data></Cell><Cell><Data ss:Type="String">No es bug</Data></Cell><Cell><Data ss:Type="String">Falta certificado de academia — PLATA requiere docs + verificadoAfip + 1 certificado</Data></Cell></Row><Row><Cell><Data ss:Type="String">#51</Data></Cell><Cell><Data ss:Type="String">No se puede revocar documento aprobado</Data></Cell><Cell><Data ss:Type="String">v2-log-niveles-bidireccional</Data></Cell><Cell><Data ss:Type="String">Fix código</Data></Cell><Cell><Data ss:Type="String">Botón Revocar validación en admin/talleres/[id] tab Formalización + aplicarNivel()</Data></Cell></Row><Row><Cell><Data ss:Type="String">#52</Data></Cell><Cell><Data ss:Type="String">No se puede testear bajada de nivel</Data></Cell><Cell><Data ss:Type="String">v2-log-niveles-bidireccional</Data></Cell><Cell><Data ss:Type="String">Fix código</Data></Cell><Cell><Data ss:Type="String">Resuelto junto con #51 — ahora se puede revocar para testear</Data></Cell></Row><Row><Cell><Data ss:Type="String">#53-60</Data></Cell><Cell><Data ss:Type="String">No se pudo probar porque sistema no cambia nivel (8 issues)</Data></Cell><Cell><Data ss:Type="String">v2-log-niveles-bidireccional</Data></Cell><Cell><Data ss:Type="String">No es bug</Data></Cell><Cell><Data ss:Type="String">Cascada de #50 — falta certificado academia para subir de nivel</Data></Cell></Row><Row><Cell><Data ss:Type="String">#61-62</Data></Cell><Cell><Data ss:Type="String">No se pudo probar porque no cambia nivel</Data></Cell><Cell><Data ss:Type="String">v2-log-niveles-bidireccional</Data></Cell><Cell><Data ss:Type="String">Deploy desactualizado</Data></Cell><Cell><Data ss:Type="String">El fix de revocar se deployó después de la auditoría</Data></Cell></Row><Row><Cell><Data ss:Type="String">#63-64</Data></Cell><Cell><Data ss:Type="String">Pedido no generó notificaciones a talleres</Data></Cell><Cell><Data ss:Type="String">v2-notificaciones-accionables</Data></Cell><Cell><Data ss:Type="String">Diseño correcto</Data></Cell><Cell><Data ss:Type="String">Matching solo envía a talleres PLATA/ORO con capacidad suficiente</Data></Cell></Row><Row><Cell><Data ss:Type="String">#65-69</Data></Cell><Cell><Data ss:Type="String">No hay notificaciones generadas (5 issues)</Data></Cell><Cell><Data ss:Type="String">v2-notificaciones-accionables</Data></Cell><Cell><Data ss:Type="String">Cascada de #63</Data></Cell><Cell><Data ss:Type="String">Sin talleres compatibles no se generan notificaciones</Data></Cell></Row><Row><Cell><Data ss:Type="String">#70</Data></Cell><Cell><Data ss:Type="String">Texto de notificación incorrecto</Data></Cell><Cell><Data ss:Type="String">v2-notificaciones-accionables</Data></Cell><Cell><Data ss:Type="String">Cascada de #63</Data></Cell><Cell><Data ss:Type="String">Sin notificaciones generadas no se puede verificar el texto</Data></Cell></Row><Row><Cell><Data ss:Type="String">#71</Data></Cell><Cell><Data ss:Type="String">No hay notificaciones en bandeja</Data></Cell><Cell><Data ss:Type="String">v2-notificaciones-accionables</Data></Cell><Cell><Data ss:Type="String">Cascada de #63</Data></Cell><Cell><Data ss:Type="String">Sin talleres compatibles no se generan notificaciones</Data></Cell></Row><Row><Cell><Data ss:Type="String">#72</Data></Cell><Cell><Data ss:Type="String">Se muestra bien correcta</Data></Cell><Cell><Data ss:Type="String">v2-notificaciones-accionables</Data></Cell><Cell><Data ss:Type="String">Falso positivo</Data></Cell><Cell><Data ss:Type="String">Sergio confirma que funciona correctamente</Data></Cell></Row><Row><Cell><Data ss:Type="String">#73</Data></Cell><Cell><Data ss:Type="String">No tiene más el cartel de nueva</Data></Cell><Cell><Data ss:Type="String">v2-notificaciones-accionables</Data></Cell><Cell><Data ss:Type="String">Falso positivo</Data></Cell><Cell><Data ss:Type="String">Comportamiento esperado — mark-as-read al click elimina el badge</Data></Cell></Row><Row><Cell><Data ss:Type="String">#74</Data></Cell><Cell><Data ss:Type="String">Error React #418 en consola</Data></Cell><Cell><Data ss:Type="String">v2-notificaciones-accionables</Data></Cell><Cell><Data ss:Type="String">Fix código</Data></Cell><Cell><Data ss:Type="String">suppressHydrationWarning en timeAgo de activity-timeline</Data></Cell></Row><Row><Cell><Data ss:Type="String">#75</Data></Cell><Cell><Data ss:Type="String">Está activo</Data></Cell><Cell><Data ss:Type="String">v2-rag-corpus-real</Data></Cell><Cell><Data ss:Type="String">Falso positivo</Data></Cell><Cell><Data ss:Type="String">Sergio confirma que funciona correctamente</Data></Cell></Row><Row><Cell><Data ss:Type="String">#76</Data></Cell><Cell><Data ss:Type="String">No se puede cargar documento RAG</Data></Cell><Cell><Data ss:Type="String">v2-rag-corpus-real</Data></Cell><Cell><Data ss:Type="String">Configuración pendiente</Data></Cell><Cell><Data ss:Type="String">Falta VOYAGE_API_KEY — RAG va en V3</Data></Cell></Row><Row><Cell><Data ss:Type="String">#77</Data></Cell><Cell><Data ss:Type="String">LLM no funciona</Data></Cell><Cell><Data ss:Type="String">v2-rag-corpus-real</Data></Cell><Cell><Data ss:Type="String">Configuración pendiente</Data></Cell><Cell><Data ss:Type="String">Falta ANTHROPIC_API_KEY — LLM va en V3</Data></Cell></Row><Row><Cell><Data ss:Type="String">#78</Data></Cell><Cell><Data ss:Type="String">3.68 segundos de carga</Data></Cell><Cell><Data ss:Type="String">v2-rag-corpus-real</Data></Cell><Cell><Data ss:Type="String">Fix performance</Data></Cell><Cell><Data ss:Type="String">396ms después de fix middleware fuentes + queries paralelas + deploy</Data></Cell></Row><Row><Cell><Data ss:Type="String">#79</Data></Cell><Cell><Data ss:Type="String">Flag asistente_rag habilitado</Data></Cell><Cell><Data ss:Type="String">v2-rag-corpus-real</Data></Cell><Cell><Data ss:Type="String">Configuración</Data></Cell><Cell><Data ss:Type="String">Desactivado en producción — sin API keys no mostrar UI</Data></Cell></Row><Row><Cell><Data ss:Type="String">#80</Data></Cell><Cell><Data ss:Type="String">Flag llm_enabled habilitado</Data></Cell><Cell><Data ss:Type="String">v2-rag-corpus-real</Data></Cell><Cell><Data ss:Type="String">Configuración</Data></Cell><Cell><Data ss:Type="String">Desactivado en producción — sin API keys no mostrar UI</Data></Cell></Row><Row><Cell><Data ss:Type="String">#81</Data></Cell><Cell><Data ss:Type="String">ESTADO → Acceso No Autorizado</Data></Cell><Cell><Data ss:Type="String">v2-seguridad-tests-e2e</Data></Cell><Cell><Data ss:Type="String">Deploy desactualizado</Data></Cell><Cell><Data ss:Type="String">Middleware ya tenía la regla correcta pero prod era del 17/04</Data></Cell></Row><Row><Cell><Data ss:Type="String">#82</Data></Cell><Cell><Data ss:Type="String">CONTENIDO → Acceso No Autorizado</Data></Cell><Cell><Data ss:Type="String">v2-seguridad-tests-e2e</Data></Cell><Cell><Data ss:Type="String">Deploy desactualizado</Data></Cell><Cell><Data ss:Type="String">Middleware ya tenía la regla correcta pero prod era del 17/04</Data></Cell></Row><Row><Cell><Data ss:Type="String">#83</Data></Cell><Cell><Data ss:Type="String">ADMIN → Acceso No Autorizado</Data></Cell><Cell><Data ss:Type="String">v2-seguridad-tests-e2e</Data></Cell><Cell><Data ss:Type="String">Deploy desactualizado</Data></Cell><Cell><Data ss:Type="String">Middleware ya tenía la regla correcta pero prod era del 17/04</Data></Cell></Row><Row><Cell><Data ss:Type="String">#84</Data></Cell><Cell><Data ss:Type="String">Página /unauthorized sin header</Data></Cell><Cell><Data ss:Type="String">v2-seguridad-tests-e2e</Data></Cell><Cell><Data ss:Type="String">Fix código</Data></Cell><Cell><Data ss:Type="String">Header PDT con nombre usuario + link Ir al panel según rol</Data></Cell></Row><Row><Cell><Data ss:Type="String">#85</Data></Cell><Cell><Data ss:Type="String">Documento subido no se ve en checklist</Data></Cell><Cell><Data ss:Type="String">v2-config-piloto-pre-deploy</Data></Cell><Cell><Data ss:Type="String">Fix código</Data></Cell><Cell><Data ss:Type="String">Botón Ver documento con signed URL Supabase (1h expiración) server-side</Data></Cell></Row><Row><Cell><Data ss:Type="String">#86</Data></Cell><Cell><Data ss:Type="String">Failed to decode downloaded font</Data></Cell><Cell><Data ss:Type="String">v2-config-piloto-pre-deploy</Data></Cell><Cell><Data ss:Type="String">Fix código</Data></Cell><Cell><Data ss:Type="String">Middleware no excluía .woff2 — fuentes redirigidas al login</Data></Cell></Row><Row><Cell><Data ss:Type="String">#87</Data></Cell><Cell><Data ss:Type="String">Tiene puntos pero no cambia a PLATA</Data></Cell><Cell><Data ss:Type="String">v2-epica-academia</Data></Cell><Cell><Data ss:Type="String">No es bug</Data></Cell><Cell><Data ss:Type="String">Mismo que #50 — falta certificado de academia</Data></Cell></Row><Row><Cell><Data ss:Type="String">#88</Data></Cell><Cell><Data ss:Type="String">KPIs confusos en admin/notificaciones</Data></Cell><Cell><Data ss:Type="String">v2-actividad