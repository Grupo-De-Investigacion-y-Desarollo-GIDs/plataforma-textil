# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.key
.certs/

# hook state/logs
.claude/hooks/.last_daily_commit
.claude/hooks/daily_hook.log

# QA HTMLs generados (tooling, no se commitean)
.claude/auditorias/*.html

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# runtime logs
dev.log
dev.out.log
dev.err.log

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.test.example

# vercel
.vercel

# prisma
prisma/generated

# typescript
*.tsbuildinfo
next-env.d.ts

# excluir del repo de codigo
*.docx
PROPUESTA_OIT_WORD.md
PROPUESTA_OIT.html
PROPUESTA_OIT_REESTRUCTURADA.md
/imagenes/
planteos_scrape/
.env*.local

# Playwright
node_modules/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/
