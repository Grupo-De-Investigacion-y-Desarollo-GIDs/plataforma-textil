# Configuracion de entorno - PDT (plataforma-textil)
# Ver variables requeridas en Vercel Dashboard → Settings → Environment Variables

# Supabase PostgreSQL
DATABASE_URL=
DIRECT_URL=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# SendGrid (emails transaccionales)
SENDGRID_API_KEY=
EMAIL_FROM=noreply@pdt.org.ar

# Supabase Storage (upload de documentos)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AFIP SDK (verificación CUIT)
AFIP_SDK_TOKEN=
AFIP_SDK_ENV=development
