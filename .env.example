# Configuracion de entorno - PDT (plataforma-textil)
# Ver variables requeridas en Vercel Dashboard → Settings → Environment Variables

# Supabase PostgreSQL
DATABASE_URL=
DIRECT_URL=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Resend (emails transaccionales)
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME=Plataforma Textil
EMAIL_SUPPORT=gbreard@gmail.com
EMAIL_REPLY_TO=gbreard@gmail.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase Storage (upload de documentos)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# RAG / Asistente IA
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# AFIP SDK / ARCA (verificación CUIT)
AFIP_SDK_TOKEN=
AFIP_SDK_ENV=development
AFIP_CUIT_PLATAFORMA=
ARCA_ENABLED=true
ARCA_PROVIDER=afipsdk
AFIP_CERT=
AFIP_KEY=

# Feedback → GitHub Issues
GITHUB_TOKEN=
GITHUB_REPO=Grupo-De-Investigacion-y-Desarollo-GIDs/plataforma-textil
